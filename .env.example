APP_NAME=Lab Borrowing System
APP_ENV=development
DEBUG=True

APP_HOST=127.0.0.1
APP_PORT=8000

DB_DRIVER=mysql+pymysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=lab_borrowing_db
DB_USER=root
DB_PASSWORD=your_password

DATABASE_URL=mysql+pymysql://root:your_password@localhost:3306/lab_borrowing_db

SECRET_KEY=replace_with_secure_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

ALLOWED_ORIGINS=*

UPLOAD_DIR=uploads/

LOG_LEVEL=INFO